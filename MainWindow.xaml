<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controle Continu 1" Height="400" Width="500" 
        x:Class="MAZOUZ_Ilyas.MainWindow" 
        Background="#F0F0F0" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:HorizontalAlignment="Center" d:VerticalAlignment="Center"> 
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="10">
            <Label Content="Value 3:"/>
            <TextBox Name="txt3" IsReadOnly="True" Text="{Binding ElementName=sld3, Path=Value, StringFormat={}{0:0}}"/>
            <Slider Name="sld3" Minimum="1" Maximum="500"/>
            <TextBlock Text="{Binding ElementName=sld3, Path=Value, StringFormat={}{0:0}}"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10">
            <Label Content="Value 1:"/>
            <TextBox Name="txt1" IsReadOnly="False" Text="{Binding ElementName=sld1, Path=Value, StringFormat={}{0:0}}"/>
            <Slider Name="sld1" Minimum="1" Maximum="500"/>
            <TextBlock Text="{Binding ElementName=sld1, Path=Value, StringFormat={}{0:0}}"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="2" Margin="10">
            <Label Content="Value 2:"/>
            <TextBox Name="txt2" IsReadOnly="True" Text="{Binding ElementName=sld2, Path=Value, StringFormat={}{0:0}}"/>
            <Slider Name="sld2" Minimum="1" Maximum="500"/>
            <TextBlock Text="{Binding ElementName=sld2, Path=Value, StringFormat={}{0:0}}"/>
        </StackPanel>

        <Label Grid.Row="1" Grid.Column="0" Content="Updated Values:" VerticalAlignment="Center" Margin="32,0,0,0"/>
        <Button Grid.Row="1" Grid.Column="1" Content="Update" Name="btnUpdate" Click="btnUpdate_Click" Width="80" Height="30" Background="#0078D7" Foreground="White"/>

        <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0">
            <Label Content="Value 1:"/>
            <Label Content="Value 2:"/>
            <Label Content="Value 3:"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0">
            <Border Background="White" Width="51.89" Height="25.96" Margin="0,0,0,5" BorderBrush="Gray" BorderThickness="0.5">
                <TextBlock Name="res1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Background="Yellow" Width="51.89" Height="25.96" Margin="0,0,0,5" BorderBrush="Gray" BorderThickness="0.5">
                <TextBlock Name="res2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Background="Cyan" Width="51.89" Height="25.96" Margin="0,0,0,5" BorderBrush="Gray" BorderThickness="0.5">
                <TextBlock Name="res3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

        <ListBox Grid.Row="2" Grid.Column="2" Name="lstValues" Margin="10">
            <ListBox.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Theme_TextColor}" />
            </ListBox.BorderBrush>
        </ListBox>
    </Grid>
</Window>
